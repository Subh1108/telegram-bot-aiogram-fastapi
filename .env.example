# Get this from @BotFather on Telegram
BOT_TOKEN=123456789:ABCDEF_your_bot_token_here

# Comma-separated Telegram user IDs that should be admins from day one
# (get your own ID by messaging @userinfobot)
ADMIN_IDS=123456789

# SQLite by default — fine for small/medium bots. Swap for Postgres later if needed.
DATABASE_URL=sqlite+aiosqlite:///./bot_database.db

# Dashboard login password (change this!)
ADMIN_PASSWORD=change-me-please

# Random long string used to sign dashboard session tokens
SECRET_KEY=please-change-this-to-something-random-and-long

API_HOST=0.0.0.0
API_PORT=8000
